{
  "name": "engineering-intelligence",
  "version": "2.0.0",
  "description": "Graph-backed engineering intelligence for AI coding IDEs. Real dependency graphs, MCP server, and installable skills/agents/workflows for 9 IDEs.",
  "type": "module",
  "homepage": "https://github.com/vinideep/engineering-intelligence#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinideep/engineering-intelligence.git"
  },
  "bugs": {
    "url": "https://github.com/vinideep/engineering-intelligence/issues"
  },
  "bin": {
    "engineering-intelligence": "./dist/cli/index.js",
    "ei-mcp": "./dist/mcp/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "npm run build && node --test test/adapters.test.mjs test/installer.test.mjs test/templates.test.mjs test/token-reduction.test.mjs test/visualizer.test.mjs test/graph.test.mjs",
    "test:integration": "npm run build && node --test test/install-integration.test.mjs test/mcp.test.mjs",
    "test:graph": "npm run build && node --test test/graph.test.mjs",
    "test:mcp": "npm run build && node --test test/mcp.test.mjs",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": [
    "agent-skills",
    "ai-ide",
    "ai-dlc",
    "agentic-workflows",
    "token-optimization",
    "agile",
    "codex",
    "claude-code",
    "cursor",
    "copilot",
    "gemini",
    "antigravity"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  }
}
